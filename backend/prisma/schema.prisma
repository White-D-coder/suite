generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String          @id @default(uuid())
  email        String          @unique
  passwordHash String
  name         String          @default("Internal User")
  role         String          @default("employee") // "owner" | "admin" | "employee" | "finance"
  createdAt    DateTime        @default(now())
  company      CompanySetting?
  
  // Relations
  assignments      ProjectAssignment[]
  accessRequests   AccessRequest[]     @relation("requester")
  approvedRequests AccessRequest[]     @relation("approver")
  salaries         SalaryRecord[]
  auditLogs        AuditLog[]
}

model CompanySetting {
  id            String   @id @default(uuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName   String?
  currency      String   @default("USD")
  invoicePrefix String   @default("INV-")
  createdAt     DateTime @default(now())
}

model Client {
  id             String          @id @default(uuid())
  name           String
  company        String?
  email          String?
  phone          String?
  country        String?
  currency       String?
  billingAddress String?
  paymentTerms   String?
  notes          String?
  createdAt      DateTime        @default(now())
  projects       Project[]
  invoices       Invoice[]
  income         Income[]
  communications Communication[]
  contacts       ClientContact[]
}

model ClientContact {
  id                  String          @id @default(uuid())
  clientId            String
  client              Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name                String
  role                String          // e.g., "decision maker", "finance contact", "technical contact", "escalation contact"
  email               String?
  primaryNumber       String?
  relationshipLabel   String?
  isPrimary           Boolean         @default(false)
  preferredForBilling Boolean         @default(false)
  preferredForUrgent  Boolean         @default(false)
  timeZone            String          @default("UTC")
  consentStatus       String          @default("granted")
  createdAt           DateTime        @default(now())
  channels            ContactChannel[]
}

model ContactChannel {
  id              String        @id @default(uuid())
  contactId       String
  contact         ClientContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  phoneType       String        // "primary phone", "alternate phone", "WhatsApp", "emergency", "escalation"
  numberOrAddress String
  isPreferred     Boolean       @default(false)
  createdAt       DateTime      @default(now())
}

model Project {
  id                 String                    @id @default(uuid())
  clientId           String
  client             Client                    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name               String
  description        String?
  status             String                    @default("active") // "active" | "completed_pending_rotation" | "rotated" | "closed"
  startDate          DateTime?
  deadline           DateTime?
  githubRepoUrl      String?
  liveUrl            String?
  stagingUrl         String?
  techStack          String[]
  hostingPlatform    String?
  databasePlatform   String?
  deploymentPlatform String?
  createdAt          DateTime                  @default(now())
  
  // Custom operational filters & location metrics
  country            String?
  state              String?
  projectCategory    String?                   // "AI" | "web" | "mobile" | "automation" | "marketing"
  serviceType        String?                   // "development" | "consulting" | "maintenance"
  contractStatus     String                    @default("active") // "active" | "inactive"
  progressStatus     String                    @default("scoping") // "scoping" | "in_progress" | "completed" | "on_hold"
  currency           String                    @default("USD")

  // Relations
  tasks                 Task[]
  websiteMonitors       WebsiteMonitor[]
  invoices              Invoice[]
  income                Income[]
  communications        Communication[]
  assignments           ProjectAssignment[]
  vaultCollections      VaultCollection[]
  accessRequests        AccessRequest[]
  contracts             ProjectContract[]
  accounts              ProjectAccount[]
  tools                 ProjectToolSubscription[]
  progressUpdates       ProjectProgressUpdate[]
  environments          ProjectEnvironment[]
  profitabilitySnapshot ProfitabilitySnapshot?
  expenses              Expense[]
  technologyLinks       ProjectTechnologyLink[]
  dispatchEntries       DispatchEntry[]
}

model ProjectContract {
  id             String    @id @default(uuid())
  projectId      String
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title          String
  contractStatus String    @default("active") // "active" | "expired" | "terminated"
  startDate      DateTime
  endDate        DateTime?
  billingModel   String    // "time_and_materials" | "fixed_price" | "retainer"
  fileUrl        String?
  createdAt      DateTime  @default(now())
}

model ProjectAccount {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  provider  String   // e.g. "Vercel", "AWS", "GitHub"
  username  String
  env       String   // "development" | "staging" | "production"
  createdAt DateTime @default(now())
}

model ProjectToolSubscription {
  id           String   @id @default(uuid())
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vendor       String   // e.g., "Sentry", "LogRocket"
  cost         Decimal  @db.Decimal(12, 2)
  billingCycle String   // "monthly" | "yearly"
  renewalDate  DateTime
  createdAt    DateTime @default(now())
}

model ProjectProgressUpdate {
  id         String   @id @default(uuid())
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  updaterId  String
  updateText String   @db.Text
  progress   Int      @default(0)
  createdAt  DateTime @default(now())
}

model ProjectEnvironment {
  id        String   @id @default(uuid())
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String   // "development" | "staging" | "production"
  url       String?
  createdAt DateTime @default(now())
}

model ProjectAssignment {
  id               String    @id @default(uuid())
  employeeId       String
  employee         User      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  projectId        String
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roleOnProject    String?
  accessLevel      String    @default("view") // "view" | "edit" | "admin"
  startDate        DateTime  @default(now())
  dueDate          DateTime?
  extendedTo       DateTime?
  extensionHistory String[]
  createdAt        DateTime  @default(now())
}

model VaultCollection {
  id               String         @id @default(uuid())
  projectId        String
  project          Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  provider         String?        // e.g. "AWS Secrets Manager", "1Password"
  rotationPolicy   String?        // e.g. "every 90 days"
  lastRotationDate DateTime?
  createdAt        DateTime       @default(now())
  secrets          VaultSecret[]
  rotationTasks    RotationTask[]
}

model VaultSecret {
  id             String               @id @default(uuid())
  collectionId   String
  collection     VaultCollection      @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  secretType     String               // "password" | "api_key" | "ssh_key"
  username       String?
  encryptedValue String               // Encrypted text
  tool           String?              // e.g. "GitHub", "Vercel"
  environment    String?              // "development" | "staging" | "production"
  owner          String?
  revealPolicy   String               @default("owner_admin_approved")
  createdAt      DateTime             @default(now())
  versions       VaultSecretVersion[]
}

model VaultSecretVersion {
  id             String      @id @default(uuid())
  secretId       String
  secret         VaultSecret @relation(fields: [secretId], references: [id], onDelete: Cascade)
  version        Int
  encryptedValue String
  createdAt      DateTime    @default(now())
}

model AccessRequest {
  id                String    @id @default(uuid())
  requesterId       String
  requester         User      @relation("requester", fields: [requesterId], references: [id], onDelete: Cascade)
  projectId         String
  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  secretScope       String    // "collection" | "secret:id"
  status            String    @default("pending") // "pending" | "approved" | "rejected" | "expired" | "revoked"
  approverId        String?
  approver          User?     @relation("approver", fields: [approverId], references: [id])
  approvalTimestamp DateTime?
  expiresAt         DateTime?
  createdAt         DateTime  @default(now())
}

model RotationTask {
  id           String          @id @default(uuid())
  collectionId String
  collection   VaultCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  status       String          @default("pending") // "pending" | "snoozed" | "completed" | "failed"
  snoozedUntil DateTime?
  reason       String?
  priority     String          @default("medium") // "high" | "medium" | "low"
  escalated    Boolean         @default(false)
  createdAt    DateTime        @default(now())
}

model Task {
  id         String    @id @default(uuid())
  projectId  String
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name       String
  assignedTo String?
  deadline   DateTime?
  progress   Int       @default(0)
  status     String    @default("pending")
  comments   String?
  createdAt  DateTime  @default(now())
}

model Communication {
  id        String   @id @default(uuid())
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      String
  subject   String?
  content   String
  sentAt    DateTime @default(now())
  direction String   @default("outgoing")
}

model InvoiceTemplate {
  id          String   @id @default(uuid())
  name        String   @default("Default Template")
  htmlContent String   @db.Text
  createdAt   DateTime @default(now())
}

model Invoice {
  id                  String            @id @default(uuid())
  clientId            String
  client              Client            @relation(fields: [clientId], references: [id])
  projectId           String?
  project             Project?          @relation(fields: [projectId], references: [id])
  invoiceNumber       String            @unique
  issueDate           DateTime
  dueDate             DateTime?
  currency            String
  subtotal            Decimal           @db.Decimal(12, 2)
  taxRate             Decimal           @db.Decimal(5, 2)
  taxAmount           Decimal           @db.Decimal(12, 2)
  total               Decimal           @db.Decimal(12, 2)
  status              String            @default("draft")
  pdfUrl              String?
  createdAt           DateTime          @default(now())
  lineItems           InvoiceLineItem[]
  income              Income[]
  schedules           InvoiceSchedule[]
  discounts           InvoiceDiscount[]

  // Multi-currency operational rules & taxes
  progressBillingMode String?           // "percentage" | "fixed" | "none"
  paidAmount          Decimal           @default(0.00) @db.Decimal(12, 2)
  remainingBalance    Decimal           @default(0.00) @db.Decimal(12, 2)
  baseCurrency        String            @default("USD")
  clientCurrency      String?
  displayCurrency     String?
  fxRate              Decimal?          @db.Decimal(10, 4)
  fxSource            String?
  fxTimestamp         DateTime?
  fxMode              String            @default("frozen") // "live" | "frozen"
  taxProfile          String?           // e.g. "inclusive" | "exclusive" | "exempt"

  // Discount fields
  discountTotal      Decimal            @default(0) @db.Decimal(12, 2)
  taxableAmount      Decimal            @default(0) @db.Decimal(12, 2)
  finalPayableAmount Decimal            @default(0) @db.Decimal(12, 2)
  discountStatus     String?            // "approved" | "pending" | null
  discountCalcOrder  String             @default("before_tax") // "before_tax" | "after_tax"
}

model InvoiceSchedule {
  id             String    @id @default(uuid())
  invoiceId      String
  invoice        Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  milestoneName  String
  percentage     Decimal?  @db.Decimal(5, 2)
  amountDue      Decimal   @db.Decimal(12, 2)
  paymentStatus  String    @default("pending") // "pending" | "paid"
  dueDate        DateTime?
  paidAmount     Decimal   @default(0.00) @db.Decimal(12, 2)
  paidAt         DateTime?
  reminderPolicy String    @default("on_due_date")
  createdAt      DateTime  @default(now())
}

model InvoiceLineItem {
  id          String   @id @default(uuid())
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Int
  unitPrice   Decimal  @db.Decimal(12, 2)
  total       Decimal  @db.Decimal(12, 2)
}

model Income {
  id            String    @id @default(uuid())
  clientId      String
  client        Client    @relation(fields: [clientId], references: [id])
  projectId     String?
  project       Project?  @relation(fields: [projectId], references: [id])
  invoiceId     String?
  invoice       Invoice?  @relation(fields: [invoiceId], references: [id])
  amount        Decimal   @db.Decimal(12, 2)
  currency      String
  exchangeRate  Decimal   @default(1.0) @db.Decimal(10, 4)
  paymentMethod String?
  paymentDate   DateTime
  status        String
}

model TaxProfile {
  id            String   @id @default(uuid())
  name          String   // e.g. "US California State Tax", "EU Standard VAT"
  rate          Decimal  @db.Decimal(5, 2)
  taxMode       String   // "inclusive" | "exclusive" | "reverse-charge" | "exempt"
  jurisdiction  String
  effectiveFrom DateTime @default(now())
  createdAt     DateTime @default(now())
}

model Expense {
  id                String    @id @default(uuid())
  description       String
  amount            Decimal   @db.Decimal(12, 2)
  currency          String
  category          String
  paymentDate       DateTime
  paymentMethod     String?
  createdAt         DateTime  @default(now())
  
  // Custom operational columns
  recurrence        String?   // "monthly" | "yearly" | "one-off"
  vendor            String?
  projectId         String?
  project           Project?  @relation(fields: [projectId], references: [id])
  status            String    @default("paid") // "paid" | "pending" | "upcoming" | "postponed"
  dueDate           DateTime?
  reminderDays      Int       @default(7)
  taxAmount         Decimal?  @db.Decimal(12, 2)
  taxProfile        String?
  receiptAttachment String?
  ownerUserId       String?
  postponedUntil    DateTime?
  postponeReason    String?
}

model Subscription {
  id           String   @id @default(uuid())
  provider     String
  serviceName  String
  cost         Decimal  @db.Decimal(12, 2)
  billingCycle String
  renewalDate  DateTime
  paymentMethod String?
  reminderDays Int      @default(30)
  createdAt    DateTime @default(now())
}

model SalaryRecord {
  id             String    @id @default(uuid())
  employeeId     String
  employee       User      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employmentType String    // "employee" | "intern" | "contractor"
  grossAmount    Decimal   @db.Decimal(12, 2)
  deductions     Decimal   @default(0.00) @db.Decimal(12, 2)
  taxAmount      Decimal   @default(0.00) @db.Decimal(12, 2)
  benefits       Decimal   @default(0.00) @db.Decimal(12, 2)
  netAmount      Decimal   @db.Decimal(12, 2)
  dueDate        DateTime
  paidDate       DateTime?
  payPeriod      String    // e.g. "2026-07"
  status         String    @default("pending") // "pending" | "paid" | "delayed"
  createdAt      DateTime  @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String   // e.g. "financial_edit", "access_approved", "password_reveal"
  details   String   @db.Text
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}

model ProfitabilitySnapshot {
  id               String   @id @default(uuid())
  projectId        String   @unique
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  revenue          Decimal  @default(0.00) @db.Decimal(12, 2)
  directCost       Decimal  @default(0.00) @db.Decimal(12, 2)
  indirectCost     Decimal  @default(0.00) @db.Decimal(12, 2)
  margin           Decimal  @default(0.00) @db.Decimal(5, 2)
  status           String   @default("healthy") // "healthy" | "borderline" | "loss-making"
  apportionmentLog String?  @db.Text
  updatedAt        DateTime @updatedAt
}

model WebsiteMonitor {
  id                String    @id @default(uuid())
  projectId         String
  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url               String
  lastStatus        String?
  sslExpiryDate     DateTime?
  domainExpiryDate  DateTime?
  hostingExpiryDate DateTime?
  lastCheckedAt     DateTime?
}

// ─────────────────────────────────────────────────────────
// INVOICE DISCOUNTS
// ─────────────────────────────────────────────────────────

model InvoiceDiscount {
  id               String   @id @default(uuid())
  invoiceId        String
  invoice          Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  invoiceItemId    String?
  discountType     String   // "percentage" | "fixed"
  discountScope    String   // "invoice" | "line_item"
  discountValue    Decimal  @db.Decimal(12, 4)
  calculatedAmount Decimal  @db.Decimal(12, 2)

  purposeCode      String
  purposeNote      String?  @db.Text

  requestedById    String
  approvedById     String?
  approvalStatus   String   @default("approved") // "approved" | "pending" | "rejected"
  approvedAt       DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// ─────────────────────────────────────────────────────────
// TECHNOLOGY VAULT
// ─────────────────────────────────────────────────────────

model TechnologyCatalogue {
  id                   String   @id @default(uuid())
  name                 String   @unique
  vendor               String?
  category             String
  logoUrl              String?
  officialUrl          String?
  supportsSubscription Boolean  @default(false)
  supportsEnvironments Boolean  @default(true)
  supportsOAuth        Boolean  @default(false)
  supportsRotation     Boolean  @default(false)
  active               Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  fieldDefinitions TechnologyFieldDefinition[]
  accounts         TechnologyAccount[]
}

model TechnologyFieldDefinition {
  id           String              @id @default(uuid())
  technologyId String
  technology   TechnologyCatalogue @relation(fields: [technologyId], references: [id], onDelete: Cascade)

  fieldKey     String
  fieldLabel   String
  fieldType    String   // "text" | "password" | "url" | "textarea" | "boolean" | "date"
  isSecret     Boolean  @default(false)
  isRequired   Boolean  @default(false)
  isRepeatable Boolean  @default(false)
  displayOrder Int      @default(0)

  createdAt DateTime @default(now())
}

model TechnologyAccount {
  id                String   @id @default(uuid())
  technologyId      String
  technology        TechnologyCatalogue @relation(fields: [technologyId], references: [id])

  accountName       String
  accountIdentifier String?
  ownerType         String   @default("agency") // "agency" | "client" | "shared"
  ownerUserId       String?
  clientId          String?

  // Subscription
  subscriptionPlan  String?
  billingCycle      String?  // "monthly" | "yearly" | "quarterly" | "lifetime" | "trial" | "one_time"
  billingAmount     Decimal? @db.Decimal(12, 2)
  billingCurrency   String?
  nextBillingDate   DateTime?
  trialEndDate      DateTime?
  autoRenewal       Boolean  @default(false)
  isLifetime        Boolean  @default(false)
  subscriptionStatus String  @default("active") // "active" | "paused" | "cancelled" | "expired" | "trial"
  reminderDays      Int[]    @default([30, 7, 1])

  // Credential health
  lastRotationDate  DateTime?
  nextRotationDate  DateTime?
  rotationPolicy    String?
  twoFactorEnabled  Boolean  @default(false)

  status     String   @default("active") // "active" | "inactive" | "deprecated"
  notes      String?  @db.Text
  tags       String[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  projectLinks    ProjectTechnologyLink[]
  environments    TechnologyEnvironment[]
  fields          TechnologyAccountField[]
  accessRequests  VaultFieldAccessRequest[]
  grants          EmployeeCredentialGrant[]
}

model ProjectTechnologyLink {
  id                  String            @id @default(uuid())
  projectId           String
  technologyAccountId String

  project           Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  technologyAccount TechnologyAccount @relation(fields: [technologyAccountId], references: [id], onDelete: Cascade)

  connectionType String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  @@unique([projectId, technologyAccountId])
}

model TechnologyEnvironment {
  id                  String            @id @default(uuid())
  technologyAccountId String
  technologyAccount   TechnologyAccount @relation(fields: [technologyAccountId], references: [id], onDelete: Cascade)

  environmentName String
  environmentType String   // "development" | "staging" | "production" | "local" | "sandbox" | "qa"
  url             String?
  active          Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fields TechnologyAccountField[]
}

model TechnologyAccountField {
  id                  String            @id @default(uuid())
  technologyAccountId String
  technologyAccount   TechnologyAccount @relation(fields: [technologyAccountId], references: [id], onDelete: Cascade)

  environmentId   String?
  environment     TechnologyEnvironment? @relation(fields: [environmentId], references: [id])
  fieldKey        String
  fieldLabel      String
  encryptedValue  String?
  nonSecretValue  String?
  isSecret        Boolean  @default(false)

  notes           String?  @db.Text
  expiresAt       DateTime?
  isLifetime      Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  grantedAccess EmployeeCredentialGrant[]
  requestedIn   VaultRequestedField[]
}

// ─────────────────────────────────────────────────────────
// FIELD-LEVEL VAULT ACCESS
// ─────────────────────────────────────────────────────────

model VaultFieldAccessRequest {
  id                  String            @id @default(uuid())
  requesterId         String
  projectId           String
  technologyAccountId String
  technologyAccount   TechnologyAccount @relation(fields: [technologyAccountId], references: [id])
  environmentId       String?

  requestReason        String  @db.Text
  taskReference        String?
  urgency              String  @default("normal") // "normal" | "high" | "critical"
  requestedDurationMin Int?

  status         String    @default("pending") // "pending" | "approved" | "partial" | "rejected" | "revoked" | "expired"
  requestedAt    DateTime  @default(now())
  reviewedAt     DateTime?
  approvedById   String?
  rejectedReason String?   @db.Text
  expiresAt      DateTime?

  requestedFields VaultRequestedField[]
}

model VaultRequestedField {
  id        String                  @id @default(uuid())
  requestId String
  request   VaultFieldAccessRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  accountFieldId String
  accountField   TechnologyAccountField @relation(fields: [accountFieldId], references: [id])

  requested Boolean  @default(true)
  approved  Boolean  @default(false)
  canReveal Boolean  @default(false)
  canCopy   Boolean  @default(false)
  singleUse Boolean  @default(false)
  usedAt    DateTime?
}

model EmployeeCredentialGrant {
  id                  String @id @default(uuid())
  employeeId          String
  projectId           String
  technologyAccountId String
  accountFieldId      String
  accountField        TechnologyAccountField @relation(fields: [accountFieldId], references: [id])
  technologyAccount   TechnologyAccount      @relation(fields: [technologyAccountId], references: [id])
  environmentId       String?

  requestId    String?
  approvedById String

  canReveal Boolean  @default(true)
  canCopy   Boolean  @default(false)
  singleUse Boolean  @default(false)
  active    Boolean  @default(true)

  grantedAt      DateTime  @default(now())
  expiresAt      DateTime?
  revokedAt      DateTime?
  lastAccessedAt DateTime?
}

// ─────────────────────────────────────────────────────────
// AI DISPATCH FEED
// ─────────────────────────────────────────────────────────

model DispatchEntry {
  id        String  @id @default(uuid())
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  clientId  String?

  communicationType String // "meeting" | "call" | "email" | "whatsapp" | "slack" | "internal_note" | "transcript" | "status_update"
  title             String
  source            String  // "manual" | "google_meet" | "zoom" | "teams" | "phone" | "email" | "whatsapp"
  sourceReference   String?

  occurredAt      DateTime
  durationMinutes Int?

  rawContent         String?  @db.Text
  aiSummary          String?  @db.Text
  aiConfidence       Decimal? @db.Decimal(5, 2)
  verificationStatus String   @default("unverified") // "unverified" | "verified" | "needs_review" | "inaccurate"

  sentiment  String? // "positive" | "neutral" | "negative" | "mixed"
  priority   String  @default("normal") // "low" | "normal" | "high" | "critical"
  followUpAt DateTime?

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  participants DispatchParticipant[]
  decisions    DispatchDecision[]
  actionItems  DispatchActionItem[]
  tags         DispatchTag[]
}

model DispatchParticipant {
  id              String        @id @default(uuid())
  dispatchEntryId String
  dispatchEntry   DispatchEntry @relation(fields: [dispatchEntryId], references: [id], onDelete: Cascade)

  participantType String  // "employee" | "client_poc" | "external"
  userId          String?
  clientContactId String?
  displayName     String
}

model DispatchDecision {
  id              String        @id @default(uuid())
  dispatchEntryId String
  dispatchEntry   DispatchEntry @relation(fields: [dispatchEntryId], references: [id], onDelete: Cascade)

  decisionText String  @db.Text
  confirmed    Boolean @default(false)
}

model DispatchActionItem {
  id              String        @id @default(uuid())
  dispatchEntryId String
  dispatchEntry   DispatchEntry @relation(fields: [dispatchEntryId], references: [id], onDelete: Cascade)

  actionText     String    @db.Text
  assignedUserId String?
  dueDate        DateTime?
  status         String    @default("open") // "open" | "in_progress" | "done" | "cancelled"
  linkedTaskId   String?
}

model DispatchTag {
  id              String        @id @default(uuid())
  dispatchEntryId String
  dispatchEntry   DispatchEntry @relation(fields: [dispatchEntryId], references: [id], onDelete: Cascade)

  tag String
}

// ─────────────────────────────────────────────────────────
// NOTIFICATIONS
// ─────────────────────────────────────────────────────────

model Notification {
  id        String   @id @default(uuid())
  userId    String
  type      String   // "credential_request" | "credential_approved" | "credential_expiring" | "subscription_expiring" | "discount_pending" | "dispatch_ready" | "action_assigned" | "invoice_overdue" | "rotation_due"
  title     String
  message   String   @db.Text
  metadata  String?  @db.Text // JSON string for extra context
  read      Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())
}
