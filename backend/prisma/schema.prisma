generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model User {
  id           String          @id @map("_id")
  email        String          @unique
  passwordHash String
  name         String          @default("Internal User")
  role         String          @default("employee") // "owner" | "admin" | "employee" | "finance"
  createdAt    DateTime        @default(now())
  company      CompanySetting?

  // Relations
  assignments      ProjectAssignment[]
  accessRequests   AccessRequest[]     @relation("requester")
  approvedRequests AccessRequest[]     @relation("approver")
  salaries         SalaryRecord[]
  auditLogs        AuditLog[]
}

model CompanySetting {
  id            String   @id @map("_id")
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  companyName   String?
  currency      String   @default("USD")
  invoicePrefix String   @default("INV-")
  createdAt     DateTime @default(now())
}

model Client {
  id             String          @id @map("_id")
  name           String
  company        String?
  email          String?
  phone          String?
  country        String?
  currency       String?
  billingAddress String?
  paymentTerms   String?
  notes          String?
  type           String?         // "agency" | "direct" | "referral" | "enterprise" | "startup"
  createdAt      DateTime        @default(now())
  projects       Project[]
  invoices       Invoice[]
  income         Income[]
  communications Communication[]
  contacts       ClientContact[]
}

model ClientContact {
  id                  String          @id @map("_id")
  clientId            String
  client              Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name                String
  role                String
  email               String?
  primaryNumber       String?
  relationshipLabel   String?
  isPrimary           Boolean         @default(false)
  preferredForBilling Boolean         @default(false)
  preferredForUrgent  Boolean         @default(false)
  timeZone            String          @default("UTC")
  consentStatus       String          @default("granted")
  createdAt           DateTime        @default(now())
  channels            ContactChannel[]
}

model ContactChannel {
  id              String        @id @map("_id")
  contactId       String
  contact         ClientContact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  phoneType       String
  numberOrAddress String
  isPreferred     Boolean       @default(false)
  createdAt       DateTime      @default(now())
}

model Project {
  id                 String                    @id @map("_id")
  clientId           String
  client             Client                    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  name               String
  description        String?
  status             String                    @default("active")
  startDate          DateTime?
  deadline           DateTime?
  githubRepoUrl      String?
  liveUrl            String?
  stagingUrl         String?
  techStack          String[]
  hostingPlatform    String?
  databasePlatform   String?
  deploymentPlatform String?
  createdAt          DateTime                  @default(now())

  country            String?
  state              String?
  projectCategory    String?
  serviceType        String?
  contractStatus     String                    @default("active")
  progressStatus     String                    @default("scoping")
  currency           String                    @default("USD")

  // Relations
  tasks                 Task[]
  websiteMonitors       WebsiteMonitor[]
  invoices              Invoice[]
  income                Income[]
  communications        Communication[]
  assignments           ProjectAssignment[]
  vaultCollections      VaultCollection[]
  accessRequests        AccessRequest[]
  contracts             ProjectContract[]
  accounts              ProjectAccount[]
  tools                 ProjectToolSubscription[]
  progressUpdates       ProjectProgressUpdate[]
  environments          ProjectEnvironment[]
  profitabilitySnapshot ProfitabilitySnapshot?
  expenses              Expense[]
  technologyLinks       ProjectTechnologyLink[]
  dispatchEntries       DispatchEntry[]
}

model ProjectContract {
  id             String    @id @map("_id")
  projectId      String
  project        Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  title          String
  contractStatus String    @default("active")
  startDate      DateTime
  endDate        DateTime?
  billingModel   String
  fileUrl        String?
  createdAt      DateTime  @default(now())
}

model ProjectAccount {
  id        String   @id @map("_id")
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  provider  String
  username  String
  env       String
  createdAt DateTime @default(now())
}

model ProjectToolSubscription {
  id           String   @id @map("_id")
  projectId    String
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  vendor       String
  cost         Float
  billingCycle String
  renewalDate  DateTime
  createdAt    DateTime @default(now())
}

model ProjectProgressUpdate {
  id         String   @id @map("_id")
  projectId  String
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  updaterId  String
  updateText String
  progress   Int      @default(0)
  createdAt  DateTime @default(now())
}

model ProjectEnvironment {
  id        String   @id @map("_id")
  projectId String
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name      String
  url       String?
  createdAt DateTime @default(now())
}

model ProjectAssignment {
  id               String    @id @map("_id")
  employeeId       String
  employee         User      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  projectId        String
  project          Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  roleOnProject    String?
  accessLevel      String    @default("view")
  startDate        DateTime  @default(now())
  dueDate          DateTime?
  extendedTo       DateTime?
  extensionHistory String[]
  createdAt        DateTime  @default(now())
}

model VaultCollection {
  id               String         @id @map("_id")
  projectId        String
  project          Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  provider         String?
  rotationPolicy   String?
  lastRotationDate DateTime?
  createdAt        DateTime       @default(now())
  secrets          VaultSecret[]
  rotationTasks    RotationTask[]
}

model VaultSecret {
  id             String               @id @map("_id")
  collectionId   String
  collection     VaultCollection      @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  secretType     String
  username       String?
  encryptedValue String
  tool           String?
  environment    String?
  owner          String?
  revealPolicy   String               @default("owner_admin_approved")
  createdAt      DateTime             @default(now())
  versions       VaultSecretVersion[]
}

model VaultSecretVersion {
  id             String      @id @map("_id")
  secretId       String
  secret         VaultSecret @relation(fields: [secretId], references: [id], onDelete: Cascade)
  version        Int
  encryptedValue String
  createdAt      DateTime    @default(now())
}

model AccessRequest {
  id                String    @id @map("_id")
  requesterId       String
  requester         User      @relation("requester", fields: [requesterId], references: [id], onDelete: Cascade)
  projectId         String
  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  secretScope       String
  status            String    @default("pending")
  approverId        String?
  approver          User?     @relation("approver", fields: [approverId], references: [id])
  approvalTimestamp DateTime?
  expiresAt         DateTime?
  createdAt         DateTime  @default(now())
}

model RotationTask {
  id           String          @id @map("_id")
  collectionId String
  collection   VaultCollection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  status       String          @default("pending")
  snoozedUntil DateTime?
  reason       String?
  priority     String          @default("medium")
  escalated    Boolean         @default(false)
  createdAt    DateTime        @default(now())
}

model Task {
  id         String    @id @map("_id")
  projectId  String
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name       String
  assignedTo String?
  deadline   DateTime?
  progress   Int       @default(0)
  status     String    @default("pending")
  comments   String?
  createdAt  DateTime  @default(now())
}

model Communication {
  id        String   @id @map("_id")
  clientId  String?
  client    Client?  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectId String?
  project   Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  type      String
  subject   String?
  content   String
  sentAt    DateTime @default(now())
  direction String   @default("outgoing")
}

model InvoiceTemplate {
  id          String   @id @map("_id")
  name        String   @default("Default Template")
  htmlContent String
  createdAt   DateTime @default(now())
}

model Invoice {
  id                  String            @id @map("_id")
  clientId            String
  client              Client            @relation(fields: [clientId], references: [id])
  projectId           String?
  project             Project?          @relation(fields: [projectId], references: [id])
  invoiceNumber       String            @unique
  issueDate           DateTime
  dueDate             DateTime?
  currency            String
  subtotal            Float
  taxRate             Float
  taxAmount           Float
  total               Float
  status              String            @default("draft")
  pdfUrl              String?
  createdAt           DateTime          @default(now())
  lineItems           InvoiceLineItem[]
  income              Income[]
  schedules           InvoiceSchedule[]
  discounts           InvoiceDiscount[]

  progressBillingMode String?
  paidAmount          Float             @default(0.00)
  remainingBalance    Float             @default(0.00)
  baseCurrency        String            @default("USD")
  clientCurrency      String?
  displayCurrency     String?
  fxRate              Float?
  fxSource            String?
  fxTimestamp         DateTime?
  fxMode              String            @default("frozen")
  taxProfile          String?

  discountTotal      Float              @default(0)
  taxableAmount      Float              @default(0)
  finalPayableAmount Float              @default(0)
  discountStatus     String?
  discountCalcOrder  String             @default("before_tax")
}

model InvoiceSchedule {
  id             String    @id @map("_id")
  invoiceId      String
  invoice        Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  milestoneName  String
  percentage     Float?
  amountDue      Float
  paymentStatus  String    @default("pending")
  dueDate        DateTime?
  paidAmount     Float     @default(0.00)
  paidAt         DateTime?
  reminderPolicy String    @default("on_due_date")
  createdAt      DateTime  @default(now())
}

model InvoiceLineItem {
  id          String   @id @map("_id")
  invoiceId   String
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  description String
  quantity    Int
  unitPrice   Float
  total       Float
}

model Income {
  id            String    @id @map("_id")
  clientId      String
  client        Client    @relation(fields: [clientId], references: [id])
  projectId     String?
  project       Project?  @relation(fields: [projectId], references: [id])
  invoiceId     String?
  invoice       Invoice?  @relation(fields: [invoiceId], references: [id])
  amount        Float
  currency      String
  exchangeRate  Float     @default(1.0)
  paymentMethod String?
  paymentDate   DateTime
  status        String
}

model TaxProfile {
  id            String   @id @map("_id")
  name          String
  rate          Float
  taxMode       String
  jurisdiction  String
  effectiveFrom DateTime @default(now())
  createdAt     DateTime @default(now())
}

model Expense {
  id                String    @id @map("_id")
  description       String
  amount            Float
  currency          String
  category          String
  paymentDate       DateTime
  paymentMethod     String?
  createdAt         DateTime  @default(now())

  recurrence        String?
  vendor            String?
  projectId         String?
  project           Project?  @relation(fields: [projectId], references: [id])
  status            String    @default("paid")
  dueDate           DateTime?
  reminderDays      Int       @default(7)
  taxAmount         Float?
  taxProfile        String?
  receiptAttachment String?
  ownerUserId       String?
  postponedUntil    DateTime?
  postponeReason    String?
}

model Subscription {
  id            String   @id @map("_id")
  provider      String
  serviceName   String
  cost          Float
  billingCycle  String
  renewalDate   DateTime
  paymentMethod String?
  reminderDays  Int      @default(30)
  createdAt     DateTime @default(now())
}

model SalaryRecord {
  id             String    @id @map("_id")
  employeeId     String
  employee       User      @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  employmentType String
  grossAmount    Float
  deductions     Float     @default(0.00)
  taxAmount      Float     @default(0.00)
  benefits       Float     @default(0.00)
  netAmount      Float
  dueDate        DateTime
  paidDate       DateTime?
  payPeriod      String
  status         String    @default("pending")
  createdAt      DateTime  @default(now())
}

model AuditLog {
  id        String   @id @map("_id")
  userId    String?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  details   String
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
}

model ProfitabilitySnapshot {
  id               String   @id @map("_id")
  projectId        String   @unique
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  revenue          Float    @default(0.00)
  directCost       Float    @default(0.00)
  indirectCost     Float    @default(0.00)
  margin           Float    @default(0.00)
  status           String   @default("healthy")
  apportionmentLog String?
  updatedAt        DateTime @updatedAt
}

model WebsiteMonitor {
  id                String    @id @map("_id")
  projectId         String
  project           Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  url               String
  lastStatus        String?
  sslExpiryDate     DateTime?
  domainExpiryDate  DateTime?
  hostingExpiryDate DateTime?
  lastCheckedAt     DateTime?
}

model InvoiceDiscount {
  id               String   @id @map("_id")
  invoiceId        String
  invoice          Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  invoiceItemId    String?
  discountType     String
  discountScope    String
  discountValue    Float
  calculatedAmount Float

  purposeCode      String
  purposeNote      String?

  requestedById    String
  approvedById     String?
  approvalStatus   String   @default("approved")
  approvedAt       DateTime?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model TechnologyCatalogue {
  id                   String   @id @map("_id")
  name                 String   @unique
  vendor               String?
  category             String
  logoUrl              String?
  officialUrl          String?
  supportsSubscription Boolean  @default(false)
  supportsEnvironments Boolean  @default(true)
  supportsOAuth        Boolean  @default(false)
  supportsRotation     Boolean  @default(false)
  active               Boolean  @default(true)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  fieldDefinitions TechnologyFieldDefinition[]
  accounts         TechnologyAccount[]
}

model TechnologyFieldDefinition {
  id           String              @id @map("_id")
  technologyId String
  technology   TechnologyCatalogue @relation(fields: [technologyId], references: [id], onDelete: Cascade)

  fieldKey     String
  fieldLabel   String
  fieldType    String
  isSecret     Boolean  @default(false)
  isRequired   Boolean  @default(false)
  isRepeatable Boolean  @default(false)
  displayOrder Int      @default(0)

  createdAt DateTime @default(now())
}

model TechnologyAccount {
  id                String   @id @map("_id")
  technologyId      String
  technology        TechnologyCatalogue @relation(fields: [technologyId], references: [id])

  accountName       String
  accountIdentifier String?
  ownerType         String   @default("agency")
  ownerUserId       String?
  clientId          String?

  subscriptionPlan  String?
  billingCycle      String?
  billingAmount     Float?
  billingCurrency   String?
  nextBillingDate   DateTime?
  trialEndDate      DateTime?
  autoRenewal       Boolean  @default(false)
  isLifetime        Boolean  @default(false)
  subscriptionStatus String  @default("active")
  reminderDays      Int[]    @default([30, 7, 1])

  lastRotationDate  DateTime?
  nextRotationDate  DateTime?
  rotationPolicy    String?
  twoFactorEnabled  Boolean  @default(false)

  status     String   @default("active")
  notes      String?
  tags       String[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  projectLinks    ProjectTechnologyLink[]
  environments    TechnologyEnvironment[]
  fields          TechnologyAccountField[]
  accessRequests  VaultFieldAccessRequest[]
  grants          EmployeeCredentialGrant[]
}

model ProjectTechnologyLink {
  id                  String            @id @map("_id")
  projectId           String
  technologyAccountId String
  project             Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  technologyAccount   TechnologyAccount @relation(fields: [technologyAccountId], references: [id], onDelete: Cascade)

  connectionType String?
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())
}

model TechnologyEnvironment {
  id                  String            @id @map("_id")
  technologyAccountId String
  technologyAccount   TechnologyAccount @relation(fields: [technologyAccountId], references: [id], onDelete: Cascade)

  environmentName String
  environmentType String
  url             String?
  active          Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fields TechnologyAccountField[]
}

model TechnologyAccountField {
  id                  String            @id @map("_id")
  technologyAccountId String
  technologyAccount   TechnologyAccount @relation(fields: [technologyAccountId], references: [id], onDelete: Cascade)

  environmentId   String?
  environment     TechnologyEnvironment? @relation(fields: [environmentId], references: [id])
  fieldKey        String
  fieldLabel      String
  encryptedValue  String?
  nonSecretValue  String?
  isSecret        Boolean  @default(false)

  notes           String?
  expiresAt       DateTime?
  isLifetime      Boolean  @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  grantedAccess EmployeeCredentialGrant[]
  requestedIn   VaultRequestedField[]
}

model VaultFieldAccessRequest {
  id                  String            @id @map("_id")
  requesterId         String
  projectId           String
  technologyAccountId String
  technologyAccount   TechnologyAccount @relation(fields: [technologyAccountId], references: [id])
  environmentId       String?

  requestReason        String
  taskReference        String?
  urgency              String  @default("normal")
  requestedDurationMin Int?

  status         String    @default("pending")
  requestedAt    DateTime  @default(now())
  reviewedAt     DateTime?
  approvedById   String?
  rejectedReason String?
  expiresAt      DateTime?

  requestedFields VaultRequestedField[]
}

model VaultRequestedField {
  id        String                  @id @map("_id")
  requestId String
  request   VaultFieldAccessRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)

  accountFieldId String
  accountField   TechnologyAccountField @relation(fields: [accountFieldId], references: [id])

  requested Boolean  @default(true)
  approved  Boolean  @default(false)
  canReveal Boolean  @default(false)
  canCopy   Boolean  @default(false)
  singleUse Boolean  @default(false)
  usedAt    DateTime?
}

model EmployeeCredentialGrant {
  id                  String @id @map("_id")
  employeeId          String
  projectId           String
  technologyAccountId String
  accountFieldId      String
  accountField        TechnologyAccountField @relation(fields: [accountFieldId], references: [id])
  technologyAccount   TechnologyAccount      @relation(fields: [technologyAccountId], references: [id])
  environmentId       String?

  requestId    String?
  approvedById String

  canReveal Boolean  @default(true)
  canCopy   Boolean  @default(false)
  singleUse Boolean  @default(false)
  active    Boolean  @default(true)

  grantedAt      DateTime  @default(now())
  expiresAt      DateTime?
  revokedAt      DateTime?
  lastAccessedAt DateTime?
}

model DispatchEntry {
  id        String  @id @map("_id")
  projectId String
  project   Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  clientId  String?

  communicationType String
  title             String
  source            String
  sourceReference   String?

  occurredAt      DateTime
  durationMinutes Int?

  rawContent         String?
  aiSummary          String?
  aiConfidence       Float?
  verificationStatus String   @default("unverified")

  sentiment  String?
  priority   String  @default("normal")
  followUpAt DateTime?

  createdById String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  participants DispatchParticipant[]
  decisions    DispatchDecision[]
  actionItems  DispatchActionItem[]
  tags         DispatchTag[]
}

model DispatchParticipant {
  id              String        @id @map("_id")
  dispatchEntryId String
  dispatchEntry   DispatchEntry @relation(fields: [dispatchEntryId], references: [id], onDelete: Cascade)

  participantType String
  userId          String?
  clientContactId String?
  displayName     String
}

model DispatchDecision {
  id              String        @id @map("_id")
  dispatchEntryId String
  dispatchEntry   DispatchEntry @relation(fields: [dispatchEntryId], references: [id], onDelete: Cascade)

  decisionText String
  confirmed    Boolean @default(false)
}

model DispatchActionItem {
  id              String        @id @map("_id")
  dispatchEntryId String
  dispatchEntry   DispatchEntry @relation(fields: [dispatchEntryId], references: [id], onDelete: Cascade)

  actionText     String
  assignedUserId String?
  dueDate        DateTime?
  status         String    @default("open")
  linkedTaskId   String?
}

model DispatchTag {
  id              String        @id @map("_id")
  dispatchEntryId String
  dispatchEntry   DispatchEntry @relation(fields: [dispatchEntryId], references: [id], onDelete: Cascade)

  tag String
}

model Notification {
  id        String   @id @map("_id")
  userId    String
  type      String
  title     String
  message   String
  metadata  String?
  read      Boolean  @default(false)
  readAt    DateTime?
  createdAt DateTime @default(now())
}
